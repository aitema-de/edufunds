# =============================================================================
# EduFunds Environment Configuration Template
# =============================================================================
# Kopiere diese Datei zu .env.local (Development) oder .env.production
# Fülle alle Werte aus und entferne nie diese Datei aus .gitignore!
# =============================================================================

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Für Docker Compose Development:
DATABASE_URL=postgresql://edufunds:dev_password@localhost:5432/edufunds

# Für Production (Railway, AWS, etc.):
# DATABASE_URL=postgresql://username:password@host:5432/database

# PostgreSQL Credentials (nur für docker-compose.yml)
POSTGRES_USER=edufunds
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=edufunds

# =============================================================================
# Email (Resend)
# =============================================================================
# API Key von https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Absender E-Mail (muss in Resend verifiziert sein)
FROM_EMAIL=noreply@edufunds.org

# Admin E-Mail für Benachrichtigungen
ADMIN_EMAIL=office@aitema.de

# Unterschrift unter der persönlichen Einleitung im Newsletter (optional)
# Default: "Kolja & das EduFunds-Team"
NEWSLETTER_SIGNATURE=Kolja & das EduFunds-Team

# =============================================================================
# Security
# =============================================================================
# Next.js Telemetry deaktivieren
NEXT_TELEMETRY_DISABLED=1

# JWT Secret (mindestens 32 Zeichen, zufällig generiert)
# Generieren: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-characters-long-change-in-production

# Löschkonzept-Cron (DSGVO Art. 5(1)e) — schützt POST /api/cron/retention
# Generieren: openssl rand -base64 32
CRON_SECRET=your-cron-secret-change-in-production
# Aufbewahrungsfristen in Tagen (optional, Defaults siehe lib/retention.ts)
# RETENTION_UNCONFIRMED_NEWSLETTER_DAYS=30
# RETENTION_ABANDONED_DRAFT_DAYS=180
# RETENTION_IP_DAYS=90

# AGB-Checkbox im Checkout (consent_collection). Default an. Auf "off" setzen,
# wenn keine ToS-URL im Stripe-Konto hinterlegt werden kann (z. B. Sandbox-
# Generalprobe) — sonst lehnt Stripe die Checkout-Session ab.
# STRIPE_TOS_CONSENT=off

# lexoffice / Lexware Office (automatische Rechnung, nur XL-Tarif)
LEXOFFICE_API_KEY=your-lexoffice-api-key
# Rechnung festschreiben (true) oder nur Entwurf (false, für Generalprobe/Tests).
# Default true. lexoffice hat KEINE Sandbox -> finalize=true = echte Nummer!
# LEXOFFICE_FINALIZE=true

# Admin Konfiguration
ADMIN_EMAIL=admin@edufunds.org
# Admin Passwort Hash (bcrypt mit 12 Rounds)
# Generieren: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('DeinSicheresPasswort123!', 12))"
ADMIN_PASSWORD_HASH=$2a$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Newsletter Admin Key (für API-Zugriff)
NEWSLETTER_ADMIN_KEY=secure-random-key-min-32-characters

# =============================================================================
# Optional: Rate Limiting
# =============================================================================
# Anzahl Requests pro Minute pro IP
# RATE_LIMIT_REQUESTS=60

# =============================================================================
# Optional: Monitoring
# =============================================================================
# Sentry DSN für Error Tracking
# SENTRY_DSN=https://xxx@yyy.sentry.io/zzz

# =============================================================================
# Optional: Redis (für Caching/Sessions)
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# AI / KI-Antragsgenerator (LLM-Provider)
# =============================================================================
# Provider-Wahl: deepseek (default) | gemini | mistral
# LLM_PROVIDER=mistral   # Produktion: NUR mistral (EU/EWR) — andere Provider werden beim Start abgelehnt

# DeepSeek (default) — von https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Gemini — von https://makersuite.google.com/app/apikey
# Kostenlos: 1.500 Anfragen/Tag, danach $0.075 pro 1M Tokens
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mistral (EU-gehostet, Frankreich) — von https://console.mistral.ai/
# DSGVO: EU-Verarbeitung als Default, AVV/DPA + Zero-Retention zuschaltbar.
# Aktivieren mit LLM_PROVIDER=mistral
MISTRAL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# Development Only
# =============================================================================
# pgAdmin Credentials (für docker-compose --profile pgadmin)
PGADMIN_EMAIL=admin@edufunds.org
PGADMIN_PASSWORD=admin

# Ports (ändern falls belegt)
NEXTJS_PORT=3101
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# =============================================================================
# Production Only (docker-compose.prod.yml)
# =============================================================================
# Domain für Traefik
# DOMAIN=edufunds.org

# Backup Retention
# BACKUP_RETENTION_DAYS=7
